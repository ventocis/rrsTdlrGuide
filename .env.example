# Copy to .env and fill in values for local development.
# Used at build time by Nuxt (only NUXT_PUBLIC_* vars are exposed to the client).
#
# Pipeline:
#   npm run generate:qa    → loads .env.qa   (SEO off, no analytics, qa.tdlrguide.com)
#   npm run generate:prod  → loads .env.production (SEO on, analytics on, tdlrguide.com)
#
# All values are non-sensitive — site URL and GA ID are visible in page source anyway.
# See .env.qa and .env.production for the committed per-environment values.

# Environment identifier ('prod' or 'qa')
NUXT_PUBLIC_ENV=prod

# Canonical site URL — used in SEO meta and sitemap
NUXT_PUBLIC_SITE_URL=https://tdlrguide.com

# Feature flags — set to 'false' on QA to disable SEO tags and GA loading
NUXT_PUBLIC_SEO_ENABLED=true
NUXT_PUBLIC_GOOGLE_ANALYTICS_ENABLED=true

# Google Analytics 4 Measurement ID
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-V9L9EMTHH6

# Formspree endpoint for form submissions
NUXT_PUBLIC_FORM_ACTION=https://formspree.io/f/maqpolpb

# Google reCAPTCHA v3 site key (leave blank to disable)
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=
