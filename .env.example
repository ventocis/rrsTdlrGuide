# Site URL (used for SEO canonical links, sitemap, og:url)
NUXT_PUBLIC_SITE_URL=https://tdlrguide.com

# Formspree endpoint for contact/review form submissions
NUXT_PUBLIC_FORM_ACTION=https://formspree.io/f/maqpolpb

# Google reCAPTCHA v3 site key (leave blank to disable)
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX, leave blank to disable)
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
