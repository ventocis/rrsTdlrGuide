---
import '../styles/global.css';
import ViewTransitions from 'astro/components/ViewTransitions.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  url?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Compare Texas defensive driving courses. TDLR-approved providers, real prices, formats, and certificate delivery. Free tools for Texas ticket dismissal.',
  keywords,
  image,
  url = '/',
  noindex = false,
  jsonLd,
  ogType = 'website',
} = Astro.props;

const siteUrl = (import.meta.env.VITE_SITE_URL || 'https://txcourseguide.com').replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${url}`;
const fullImageUrl = image ? (image.startsWith('http') ? image : `${siteUrl}${image}`) : undefined;
const enableAnalytics = import.meta.env.VITE_ENABLE_ANALYTICS === 'true';
const ga4Id = import.meta.env.VITE_GA4_ID;
const isNoindex = noindex || import.meta.env.VITE_ENABLE_SEO !== 'true';
const pageTitle = title.includes('TX Course Guide') ? title : `${title} | TX Course Guide`;

const jsonLdScripts = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalUrl} />
    {isNoindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {fullImageUrl && <meta property="og:image" content={fullImageUrl} />}
    <meta property="og:site_name" content="TX Course Guide" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {fullImageUrl && <meta name="twitter:image" content={fullImageUrl} />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts: preconnect then load with display=optional (eliminates font-swap CLS) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=optional"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=optional"
      rel="stylesheet"
    />

    <!-- JSON-LD structured data -->
    {jsonLdScripts.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Google Analytics — production only -->
    {enableAnalytics && ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
      </>
    )}
  </head>
  <body class="w-full overflow-x-hidden m-0 p-0" style="background-color: var(--proto-page-bg); font-family: 'DM Sans', system-ui, sans-serif; color: var(--proto-text);">

    <!-- Live Q&A schedule banner -->
    <div id="live-banner" style="display:none; width:100%; padding:8px 16px; text-align:center; font-size:12px; font-weight:600; position:relative; z-index:100;">
      <a id="live-banner-link" href="/live" style="color:inherit; text-decoration:none; display:inline-flex; align-items:center; gap:6px; flex-wrap:wrap; justify-content:center;">
        <span id="live-dot" style="display:inline-block; width:8px; height:8px; border-radius:50%; background:currentColor; flex-shrink:0;"></span>
        <span id="live-banner-text"></span>
      </a>
      <button id="live-banner-close" aria-label="Dismiss" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; font-size:16px; cursor:pointer; color:inherit; opacity:0.6; line-height:1;">×</button>
    </div>
    <script is:inline>
      (function() {
        var YOUTUBE_URL = 'https://youtube.com/@txcourseguide';
        // MWF = days 1,3,5. Show time: 5:30 PM ET = 21:30 UTC (EST) / 20:30 UTC (EDT)
        // Texas is CT = ET-1h. Display as "4:30 PM CT / 5:30 PM ET"
        var LIVE_DAYS = [1, 3, 5]; // Mon=1, Wed=3, Fri=5
        var LIVE_HOUR_ET = 17; // 5 PM ET
        var LIVE_MIN_ET = 30;  // :30
        var LIVE_DURATION_MIN = 30;

        function getETOffset() {
          // Approximate ET offset: EDT = UTC-4, EST = UTC-5
          var jan = new Date(new Date().getFullYear(), 0, 1).getTimezoneOffset();
          var jul = new Date(new Date().getFullYear(), 6, 1).getTimezoneOffset();
          var stdOffset = Math.max(jan, jul); // EST = 300min
          var now = new Date();
          var isDST = now.getTimezoneOffset() < stdOffset;
          return isDST ? -4 : -5; // hours from UTC
        }

        function isLiveNow() {
          var now = new Date();
          var etOffset = getETOffset();
          var utcMs = now.getTime() + now.getTimezoneOffset() * 60000;
          var etNow = new Date(utcMs + etOffset * 3600000);
          var day = etNow.getDay();
          if (!LIVE_DAYS.includes(day)) return false;
          var startMin = LIVE_HOUR_ET * 60 + LIVE_MIN_ET;
          var curMin = etNow.getHours() * 60 + etNow.getMinutes();
          return curMin >= startMin && curMin < startMin + LIVE_DURATION_MIN;
        }

        function nextLiveDay() {
          var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
          var now = new Date();
          var etOffset = getETOffset();
          var utcMs = now.getTime() + now.getTimezoneOffset() * 60000;
          var etNow = new Date(utcMs + etOffset * 3600000);
          var today = etNow.getDay();
          // Find next live day
          for (var i = 1; i <= 7; i++) {
            var d = (today + i) % 7;
            if (LIVE_DAYS.includes(d)) return days[d];
          }
          return 'Monday';
        }

        var banner = document.getElementById('live-banner');
        var bannerLink = document.getElementById('live-banner-link');
        var bannerText = document.getElementById('live-banner-text');
        var dot = document.getElementById('live-dot');
        var closeBtn = document.getElementById('live-banner-close');

        if (sessionStorage.getItem('live-banner-dismissed')) return;

        if (isLiveNow()) {
          banner.style.display = 'block';
          banner.style.background = '#dc2626';
          banner.style.color = '#fff';
          dot.style.background = '#fff';
          dot.style.animation = 'livepulse 1.2s ease-in-out infinite';
          bannerText.textContent = "We're live right now! Join the free Texas ticket Q&A →";
          bannerLink.href = YOUTUBE_URL;
          // Add pulse keyframes
          if (!document.getElementById('live-pulse-style')) {
            var s = document.createElement('style');
            s.id = 'live-pulse-style';
            s.textContent = '@keyframes livepulse{0%,100%{opacity:1}50%{opacity:0.3}}';
            document.head.appendChild(s);
          }
        } else {
          banner.style.display = 'block';
          banner.style.background = '#0f172a';
          banner.style.color = '#94a3b8';
          dot.style.display = 'none';
          bannerText.textContent = 'Free Live Q&A — Mon · Wed · Fri at 4:30 PM CT (5:30 PM ET) · Ask your Texas ticket questions →';
          bannerLink.href = '/live';
        }

        closeBtn.addEventListener('click', function() {
          banner.style.display = 'none';
          sessionStorage.setItem('live-banner-dismissed', '1');
        });
      })();
    </script>

    <slot />

    <!-- Trustpilot popup — shows after 60s, sessionStorage-gated -->
    <div id="tp-popup" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:9999; align-items:center; justify-content:center;">
      <div id="tp-popup-inner" style="background:#fff; border-radius:12px; padding:24px; width:300px; position:relative; font-family:'DM Sans',sans-serif;">
        <button id="tp-close-x" style="position:absolute;top:10px;right:14px;background:none;border:none;font-size:20px;cursor:pointer;color:#888;">×</button>
        <p style="font-size:13px;font-weight:600;margin:0 0 4px;color:#111;">Was TX Course Guide helpful?</p>
        <p style="font-size:12px;color:#666;margin:0 0 16px;">Leave a quick review — it helps other Texas drivers find us.</p>
        <a id="tp-review-link" href="https://www.trustpilot.com/review/txcourseguide.com" target="_blank" rel="noopener"
          style="display:block;background:#00b67a;color:#fff;text-align:center;padding:10px;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;">
          Leave a review →
        </a>
        <button id="tp-maybe-later" style="display:block;width:100%;margin-top:8px;background:none;border:none;font-size:11px;color:#999;cursor:pointer;">Maybe later</button>
      </div>
    </div>
    <script is:inline>
      (function() {
        var popup = document.getElementById('tp-popup');
        function dismissTpPopup() {
          popup.style.display = 'none';
          sessionStorage.setItem('tp-popup-dismissed', '1');
        }
        popup.addEventListener('click', function(e) {
          if (e.target === popup) dismissTpPopup();
        });
        document.getElementById('tp-close-x').addEventListener('click', dismissTpPopup);
        document.getElementById('tp-maybe-later').addEventListener('click', dismissTpPopup);
        document.getElementById('tp-review-link').addEventListener('click', dismissTpPopup);
        if (!sessionStorage.getItem('tp-popup-dismissed')) {
          setTimeout(function() { popup.style.display = 'flex'; }, 60000);
        }
      })();
    </script>

    <!-- Trustpilot floating bar -->
    <div id="tp-float" style="position:fixed;bottom:16px;right:16px;left:16px;max-width:480px;margin:0 auto;background:#fff;border:1px solid #e0e0e0;border-radius:10px;padding:10px 16px;display:flex;align-items:center;gap:10px;z-index:9998;box-shadow:0 2px 12px rgba(0,0,0,0.08);">
      <span style="font-size:18px;color:#00b67a;letter-spacing:-1px;">★★★★★</span>
      <span style="flex:1;font-size:12px;color:#444;"><strong>Found this helpful?</strong> Review us on Trustpilot</span>
      <a href="https://www.trustpilot.com/review/txcourseguide.com" target="_blank" rel="noopener"
        style="background:#00b67a;color:#fff;padding:7px 14px;border-radius:6px;font-size:12px;font-weight:600;text-decoration:none;white-space:nowrap;">
        Review us
      </a>
      <button id="tp-float-close" style="background:none;border:none;font-size:18px;color:#aaa;cursor:pointer;padding:0 0 0 4px;line-height:1;">×</button>
    </div>
    <script is:inline>
      (function() {
        var bar = document.getElementById('tp-float');
        if (sessionStorage.getItem('tp-float-dismissed')) {
          bar.style.display = 'none';
        }
        document.getElementById('tp-float-close').addEventListener('click', function() {
          bar.style.display = 'none';
          sessionStorage.setItem('tp-float-dismissed', '1');
        });
      })();
    </script>

  </body>
</html>
