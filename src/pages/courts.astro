---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CourtsFilter from '../components/CourtsFilter';
import courtsRaw from '../data/courts.json';

const courts = courtsRaw as any[];
const siteUrl = (import.meta.env.VITE_SITE_URL || 'https://txcourseguide.com').replace(/\/$/, '');

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Texas Court Lookup',
  description: 'Look up any Texas Justice of the Peace or Municipal court by county.',
  url: `${siteUrl}/courts`,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'TX Course Guide', url: siteUrl }
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'TX Course Guide', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Texas Court Lookup', item: `${siteUrl}/courts` }
  ]
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I find my Texas court for a traffic ticket?', acceptedAnswer: { '@type': 'Answer', text: 'Use the Texas Court Lookup at txcourseguide.com/courts. Select your county and court type (Justice of the Peace or Municipal) to find your court\'s judge name, phone number, email, and website. Your citation should also list the court name or precinct number.' } },
    { '@type': 'Question', name: 'What is the difference between a JP Court and a Municipal Court in Texas?', acceptedAnswer: { '@type': 'Answer', text: 'Justice of the Peace (JP) Courts handle citations issued in unincorporated county areas and some smaller cities. Municipal Courts handle citations issued within incorporated city limits. For example, a ticket issued inside Houston city limits goes to Houston Municipal Court; one issued in unincorporated Harris County goes to a Harris County JP Court.' } },
    { '@type': 'Question', name: 'How do I contact my Texas court to request defensive driving?', acceptedAnswer: { '@type': 'Answer', text: 'Use the court\'s phone number or email found in the Texas Court Lookup. Contact them before your appearance date to request permission to take a Driver Safety Course (DSC). Do not enroll in a course before receiving approval.' } },
    { '@type': 'Question', name: 'Why do I need to contact my court before taking defensive driving?', acceptedAnswer: { '@type': 'Answer', text: 'Texas law requires you to receive court approval before enrolling in and completing a defensive driving course for ticket dismissal. Taking the course without prior court approval is a common mistake that results in the dismissal being denied.' } },
  ]
};
---

<Layout
  title="Texas Court Lookup — Find Your JP or Municipal Court | TX Course Guide"
  description="Look up any Texas Justice of the Peace or Municipal court by county. Get judge name, phone, email, and website for defensive driving ticket dismissal."
  keywords="Texas court lookup, JP court Texas, municipal court Texas, Justice of the Peace, court directory Texas"
  url="/courts"
  jsonLd={[jsonLdWebApp, breadcrumb, faqLd]}
>
  <div class="min-h-screen" style="background-color: var(--proto-page-bg); font-family: 'DM Sans', system-ui, sans-serif;">
    <SiteHeader currentPath="/courts" />
    <main class="mx-auto w-full max-w-[960px] px-4 py-8 sm:px-6" role="main">
      <header class="mb-6" aria-label="Page header">
        <h1 class="mb-2 text-2xl font-bold leading-tight sm:text-3xl" style="color: var(--proto-text);">
          Texas Court Lookup — Find Your JP or Municipal Court
        </h1>
        <p class="max-w-[640px] text-[14px]" style="color: var(--proto-text-muted);">
          Look up any Texas Justice of the Peace or Municipal court by county.
          Get judge name, phone, email, and website for defensive driving and ticket dismissal.
        </p>
      </header>

      <CourtsFilter courts={courts} client:load />

      <section
        class="mt-4 rounded-2xl border px-4 py-4 sm:px-6 sm:py-5"
        style="background: var(--proto-teal-bg); border-color: var(--proto-teal-border);"
        aria-labelledby="eligibility-cta-heading"
      >
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 id="eligibility-cta-heading" class="mb-1 text-base font-semibold sm:text-lg" style="color: var(--proto-text);">
              Not sure if you qualify for defensive driving?
            </h2>
            <p class="m-0 max-w-[520px] text-[13px]" style="color: var(--proto-text-muted);">
              Answer 5 quick questions to find out if your ticket is eligible for dismissal — and get your exact next steps.
            </p>
          </div>
          <a
            href="/eligibility-checker"
            class="inline-flex items-center justify-center rounded-lg px-4 py-2.5 text-[13px] font-semibold text-white transition-colors"
            style="background: var(--proto-header-from);"
          >
            Check My Eligibility →
          </a>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</Layout>
