---
import providersRaw from '../data/providers.json';

const providers = providersRaw as any[];
const totalProviders = providers.length;
const totalBrands = providers.reduce((sum: number, p: any) => sum + 1 + (p.duplicates?.length || 0), 0);
---

<footer
  class="border-t bg-white"
  style="border-color: var(--proto-card-border);"
>
  <div class="mx-auto w-full max-w-[1600px] px-4 py-8 sm:px-6">

    <!-- Top row: brand + data date -->
    <div class="flex flex-wrap items-start justify-between gap-4 pb-6" style="border-bottom: 1px solid var(--proto-card-border);">
      <div>
        <p class="text-[13px] font-semibold" style="color: var(--proto-text);">TX Course Guide</p>
        <p class="mt-0.5 text-[11px]" style="color: var(--proto-text-muted);">Operated by Road Ready Driver Instruction LLC</p>
        <p class="mt-0.5 text-[11px]" style="color: var(--proto-text-light);">Compare {totalProviders} unique providers · {totalBrands} total brand names</p>
      </div>
      <p class="text-[11px]" style="color: var(--proto-text-light);">Data last updated: Mar 9, 2026</p>
    </div>

    <!-- Middle: links in two groups -->
    <div class="flex flex-wrap gap-x-10 gap-y-5 py-6" style="border-bottom: 1px solid var(--proto-card-border);">
      <!-- Tools -->
      <div>
        <p class="mb-2 text-[10px] font-bold uppercase tracking-wider" style="color: var(--proto-label);">Tools</p>
        <div class="flex flex-col gap-1.5">
          <a href="/" class="text-[12px] font-medium" style="color: var(--proto-teal);">Compare Courses</a>
          <a href="/eligibility-checker" class="text-[12px] font-medium" style="color: var(--proto-teal);">Eligibility Checker</a>
          <a href="/courts" class="text-[12px] font-medium" style="color: var(--proto-teal);">Court Lookup</a>
          <a href="/ticket-calculator" class="text-[12px] font-medium" style="color: var(--proto-teal);">Ticket Calculator</a>
          <a href="/pricing" class="text-[12px] font-medium" style="color: var(--proto-teal);">Pricing Guide</a>
          <a href="/cheapest-texas-defensive-driving-courses" class="text-[12px] font-medium" style="color: var(--proto-teal);">Cheapest Courses List</a>
          <a href="/faq" class="text-[12px] font-medium" style="color: var(--proto-teal);">FAQ</a>
        </div>
      </div>

      <!-- Connect -->
      <div>
        <p class="mb-2 text-[10px] font-bold uppercase tracking-wider" style="color: var(--proto-label);">Connect</p>
        <div class="flex flex-col gap-1.5">
          <a href="/live" class="text-[12px] font-medium" style="color: var(--proto-teal);">Live Q&amp;A</a>
          <a href="https://youtube.com/@txcourseguide" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-[12px] font-medium" style="color: var(--proto-teal);">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            YouTube
          </a>
          <a href="mailto:info@txcourseguide.com" class="text-[12px] font-medium" style="color: var(--proto-teal);">info@txcourseguide.com</a>
        </div>
      </div>

      <!-- Legal -->
      <div>
        <p class="mb-2 text-[10px] font-bold uppercase tracking-wider" style="color: var(--proto-label);">Legal</p>
        <div class="flex flex-col gap-1.5">
          <a href="/privacy" class="text-[12px] font-medium" style="color: var(--proto-teal);">Privacy Policy</a>
          <a href="/terms" class="text-[12px] font-medium" style="color: var(--proto-teal);">Terms of Use</a>
        </div>
      </div>
    </div>

    <!-- Bottom: consolidated disclaimers -->
    <div class="flex flex-col gap-2 pt-5 text-[10px] leading-relaxed" style="color: var(--proto-text-muted);">
      <p class="m-0">
        This site is for informational and comparison purposes only. We are not affiliated with TDLR or the State of Texas. Prices and details may change; always verify with the provider and TDLR before making decisions.
        Use of this site is subject to our <a href="/terms" class="underline" style="color: var(--proto-teal);">Terms of Use</a> and <a href="/privacy" class="underline" style="color: var(--proto-teal);">Privacy Policy</a>.
      </p>
      <p class="m-0">
        <strong>Affiliate disclosure:</strong> TX Course Guide may earn a commission when you purchase a course through links on this site. This does not affect our rankings or editorial independence.
        All provider listings are based on publicly available TDLR records.
      </p>
      <p class="m-0">Operated by Road Ready Driver Instruction LLC.</p>
    </div>

  </div>
</footer>
